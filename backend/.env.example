# Copy to .env for local dev. Never commit the real .env.
DATABASE_URL=postgresql+asyncpg://argus:argus@localhost:5432/argus
ENVIRONMENT=development

# LLM impact scoring (Ollama). Pull the model once: `ollama pull llama3.2`
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2

# Notion CRM (optional — sync is skipped until both are set).
# See backend/scripts/setup_notion.py to create the database.
NOTION_TOKEN=
NOTION_DATABASE_ID=
