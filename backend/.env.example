# Copy to .env for local dev. Never commit the real .env.
DATABASE_URL=postgresql+asyncpg://argus:argus@localhost:5432/argus
ENVIRONMENT=development

# LLM impact scoring (Ollama). Pull the model once: `ollama pull llama3.2`
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2

# Notion CRM (optional — sync is skipped until both are set).
# See backend/scripts/setup_notion.py to create the database.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Digest email (SMTP — e.g. Gmail with an app password). Skipped until set.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_FROM=
DIGEST_TO=
DIGEST_FREQUENCY=daily

# API key for the Chrome extension / external clients. Empty = endpoints open.
API_KEY=
